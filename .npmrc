provenance=true

# Supply-chain hardening: don't resolve package versions newer than 7 days, so a
# freshly-published malicious/compromised version can't slip into an install.
# `min-release-age` (days) is the npm key; pnpm's equivalent lives in
# pnpm-workspace.yaml as `minimumReleaseAge` (single source of truth for pnpm).
min-release-age=7
