{
  "name": "@posthog/brand",
  "version": "0.0.1",
  "description": "PostHog's brand assets — hedgehog illustrations, logos, team crests, and brand colors as React components, raw SVGs, PNG URLs, and tokens. Bundled, offline, tree-shakeable.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "PostHog <hey@posthog.com>",
  "homepage": "https://github.com/PostHog/hedgehogs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostHog/hedgehogs.git"
  },
  "bugs": {
    "url": "https://github.com/PostHog/hedgehogs/issues"
  },
  "keywords": [
    "posthog",
    "brand",
    "hedgehog",
    "hedgehogs",
    "logo",
    "crest",
    "colors",
    "illustrations",
    "svg",
    "react",
    "icons"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./hoggies": {
      "types": "./dist/generated/hoggies/components/index.d.mts",
      "default": "./dist/generated/hoggies/components/index.mjs"
    },
    "./hoggies/svg": {
      "types": "./dist/generated/hoggies/svg/index.d.mts",
      "default": "./dist/generated/hoggies/svg/index.mjs"
    },
    "./hoggies/svg/*": {
      "types": "./dist/generated/hoggies/svg/*.d.mts",
      "default": "./dist/generated/hoggies/svg/*.mjs"
    },
    "./hoggies/png": {
      "types": "./dist/generated/hoggies/png/index.d.mts",
      "default": "./dist/generated/hoggies/png/index.mjs"
    },
    "./hoggies/png/*": {
      "types": "./dist/generated/hoggies/png/*.d.mts",
      "default": "./dist/generated/hoggies/png/*.mjs"
    },
    "./hoggies/metadata": {
      "types": "./dist/generated/hoggies/manifest.d.mts",
      "default": "./dist/generated/hoggies/manifest.mjs"
    },
    "./logo": {
      "types": "./dist/logo/index.d.mts",
      "default": "./dist/logo/index.mjs"
    },
    "./crests": {
      "types": "./dist/generated/crests/index.d.mts",
      "default": "./dist/generated/crests/index.mjs"
    },
    "./crests/full": {
      "types": "./dist/generated/crests/full/components/index.d.mts",
      "default": "./dist/generated/crests/full/components/index.mjs"
    },
    "./crests/full/svg": {
      "types": "./dist/generated/crests/full/svg/index.d.mts",
      "default": "./dist/generated/crests/full/svg/index.mjs"
    },
    "./crests/full/svg/*": {
      "types": "./dist/generated/crests/full/svg/*.d.mts",
      "default": "./dist/generated/crests/full/svg/*.mjs"
    },
    "./crests/full/png": {
      "types": "./dist/generated/crests/full/png/index.d.mts",
      "default": "./dist/generated/crests/full/png/index.mjs"
    },
    "./crests/full/png/*": {
      "types": "./dist/generated/crests/full/png/*.d.mts",
      "default": "./dist/generated/crests/full/png/*.mjs"
    },
    "./crests/full/metadata": {
      "types": "./dist/generated/crests/full/manifest.d.mts",
      "default": "./dist/generated/crests/full/manifest.mjs"
    },
    "./crests/mini": {
      "types": "./dist/generated/crests/mini/components/index.d.mts",
      "default": "./dist/generated/crests/mini/components/index.mjs"
    },
    "./crests/mini/svg": {
      "types": "./dist/generated/crests/mini/svg/index.d.mts",
      "default": "./dist/generated/crests/mini/svg/index.mjs"
    },
    "./crests/mini/svg/*": {
      "types": "./dist/generated/crests/mini/svg/*.d.mts",
      "default": "./dist/generated/crests/mini/svg/*.mjs"
    },
    "./crests/mini/png": {
      "types": "./dist/generated/crests/mini/png/index.d.mts",
      "default": "./dist/generated/crests/mini/png/index.mjs"
    },
    "./crests/mini/png/*": {
      "types": "./dist/generated/crests/mini/png/*.d.mts",
      "default": "./dist/generated/crests/mini/png/*.mjs"
    },
    "./crests/mini/metadata": {
      "types": "./dist/generated/crests/mini/manifest.d.mts",
      "default": "./dist/generated/crests/mini/manifest.mjs"
    },
    "./colors": {
      "types": "./dist/colors.d.mts",
      "default": "./dist/colors.mjs"
    },
    "./colors/css": {
      "types": "./dist/colors-css.d.mts",
      "default": "./dist/colors-css.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "node scripts/sync.ts",
    "codegen": "node scripts/codegen.ts",
    "prebuild": "pnpm codegen",
    "build": "tsdown",
    "pretest": "pnpm codegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxfmt --write .",
    "size": "node scripts/size-report.ts",
    "dev:site": "pnpm build && pnpm --filter @posthog/brand-site dev",
    "build:site": "pnpm build && pnpm --filter @posthog/brand-site build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@napi-rs/image": "^1.12.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "p-limit": "^7.3.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svgo": "^4.0.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
