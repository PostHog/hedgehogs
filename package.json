{
  "name": "@posthog/hedgehogs",
  "version": "0.1.0",
  "description": "PostHog's hedgehog illustration library — React components, raw SVGs, and searchable metadata. Bundled, offline, zero runtime CDN.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "PostHog <hey@posthog.com>",
  "homepage": "https://github.com/PostHog/posthog-hedgehogs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostHog/posthog-hedgehogs.git"
  },
  "bugs": {
    "url": "https://github.com/PostHog/posthog-hedgehogs/issues"
  },
  "keywords": [
    "posthog",
    "hedgehog",
    "hedgehogs",
    "illustrations",
    "svg",
    "react",
    "icons"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./svg": {
      "types": "./dist/svg.d.mts",
      "default": "./dist/svg.mjs"
    },
    "./svg/*": {
      "types": "./dist/generated/svg/*.d.mts",
      "default": "./dist/generated/svg/*.mjs"
    },
    "./png": {
      "types": "./dist/png.d.mts",
      "default": "./dist/png.mjs"
    },
    "./png/*": {
      "types": "./dist/generated/png/*.d.mts",
      "default": "./dist/generated/png/*.mjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.mts",
      "default": "./dist/metadata.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "node scripts/sync.ts",
    "codegen": "node scripts/codegen.ts",
    "prebuild": "pnpm codegen",
    "build": "tsdown",
    "pretest": "pnpm codegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && prettier --check .",
    "format": "prettier --write .",
    "size": "node scripts/size-report.ts",
    "migration-report": "node scripts/migration-report.ts",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.70.0",
    "p-limit": "^7.3.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svgo": "^4.0.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
